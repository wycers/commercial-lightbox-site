---
type Props = {
  kicker: string;
  title: string;
  copy: string;
};

const { kicker, title, copy } = Astro.props;
---

<div class="max-w-2xl">
  <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-700">
    {kicker}
  </p>
  <h2
    class="mt-3 text-balance text-3xl font-semibold tracking-normal text-stone-950 md:text-4xl"
  >
    {title}
  </h2>
  <p class="mt-4 text-pretty text-base leading-7 text-stone-600">{copy}</p>
</div>
