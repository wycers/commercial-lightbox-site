---
import SectionHeader from "../components/SectionHeader.astro";
import QuoteForm from "../components/QuoteForm";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Send } from "lucide-react";
import {
  businessAbn,
  businessName,
  companyName,
  contactEmail,
  contactPhone,
  emailHref,
  fuelPriceBoardUrl,
  phoneHref,
  serviceArea,
  siteName,
  siteUrl,
} from "../lib/site";

const title = "Commercial Lightbox Signs WA | Perth Lightbox Signage";
const description =
  "Custom commercial lightbox signs for Perth and regional WA businesses, including indoor, shopfront, menu, fascia, and outdoor lightboxes.";

const heroHighlights = [
  ["WA service", `${serviceArea} site scoping`],
  ["Full path", "Design, fabricate, install"],
  ["Reply", "Quote response within 1 business day"],
];

const contactLinks = [
  contactPhone
    ? {
        label: "Call",
        value: contactPhone,
        href: phoneHref(contactPhone),
      }
    : null,
  contactEmail
    ? {
        label: "Email",
        value: contactEmail,
        href: emailHref(contactEmail),
      }
    : null,
].filter(Boolean) as Array<{ label: string; value: string; href: string }>;

const placeholderImages = {
  shopfront: {
    src: "/images/commercial-lightbox-shopfront-placeholder.png",
    alt: "Illuminated shopfront lightbox sign concept on a modern commercial frontage",
  },
  indoor: {
    src: "/images/commercial-lightbox-indoor-placeholder.png",
    alt: "Indoor commercial lightbox sign concept in a reception setting",
  },
  detail: {
    src: "/images/commercial-lightbox-detail-placeholder.png",
    alt: "Commercial lightbox cabinet detail showing diffuser, LEDs, and aluminium housing",
  },
};

const serviceCards = [
  {
    title: "Shopfront lightbox signs",
    href: "/shopfront-lightbox-signs-perth",
    image: placeholderImages.shopfront,
    copy: "Fascia, wall-mounted, and window-facing signs planned for street visibility, structure, weather, and access.",
  },
  {
    title: "Indoor lightbox signs",
    href: "/indoor-lightbox-signs",
    image: placeholderImages.indoor,
    copy: "Reception, brand wall, showroom, and retail interior lightboxes with clean finishes and comfortable brightness.",
  },
  {
    title: "Outdoor lightbox signs",
    href: "/outdoor-lightbox-signs",
    image: placeholderImages.shopfront,
    copy: "Weather-aware illuminated cabinets for exposed shopfronts, commercial walls, and mixed-use sites.",
  },
  {
    title: "Menu lightbox signs",
    href: "/menu-lightbox-signs",
    image: placeholderImages.indoor,
    copy: "Food court, counter, and menu lightboxes that stay readable up close without overpowering queues or seating.",
  },
];

const exampleProjects = [
  {
    title: "Shopfront fascia lightbox",
    image: placeholderImages.shopfront,
    scope: "Illustrative example for street-facing tenancy signage",
    details: [
      "Future case fields: suburb or industry",
      "Rough sign size and cabinet depth",
      "Mounting, access, and power notes",
    ],
  },
  {
    title: "Indoor reception lightbox",
    image: placeholderImages.indoor,
    scope: "Illustrative example for close-viewing interior signage",
    details: [
      "Future case fields: fit-out finish",
      "Face material and brightness notes",
      "Cleaning and service access notes",
    ],
  },
  {
    title: "Cabinet and face detail",
    image: placeholderImages.detail,
    scope: "Illustrative example for material and maintenance scoping",
    details: [
      "Future case fields: face material",
      "LED, diffuser, and service access notes",
      "Warranty and support assumptions",
    ],
  },
];

const priceGuidance = [
  {
    title: "First reply gives direction",
    copy: "When photos, rough dimensions, location, and sign type are supplied, the first reply can outline a practical pricing path or the next scope questions.",
  },
  {
    title: "Formal quotes are site-specific",
    copy: "Final pricing is confirmed after material, cabinet size, artwork, access, power, travel, approvals, and installation assumptions are clear.",
  },
  {
    title: "No hidden generic size chart",
    copy: "Two signs with the same face size can price differently when wall condition, weather exposure, service access, or electrical coordination changes.",
  },
];

const quoteFactors = [
  {
    title: "Sign size and face",
    copy: "Dimensions, artwork quality, acrylic or polycarbonate face material, and replacement access shape the build.",
  },
  {
    title: "Indoor or outdoor use",
    copy: "Indoor signs need comfortable diffusion. Outdoor signs add UV, weather, drainage, fixing, and exposure details.",
  },
  {
    title: "Mounting and power",
    copy: "Wall condition, cable paths, switching, access equipment, and power coordination can change the install scope.",
  },
  {
    title: "Timing and approvals",
    copy: "Artwork readiness, tenancy rules, landlord approvals, travel, and permit needs affect the final delivery path.",
  },
];

const materialCareItems = [
  {
    title: "Cabinet and face",
    copy: "Quotes should identify the cabinet approach, face material, finish, drainage or interior edge detail, and how the face can be accessed later.",
  },
  {
    title: "LEDs and brightness",
    copy: "LED layout, diffuser choice, power supply, colour contrast, and brightness are matched to viewing distance and whether the sign is indoor or outdoor.",
  },
  {
    title: "Warranty and support",
    copy: "Warranty terms, exclusions, and support assumptions should be written into the quote before fabrication, rather than implied after install.",
  },
  {
    title: "Maintenance path",
    copy: "Cleaning, future face replacement, LED service access, and power-supply access should be considered while the cabinet is being scoped.",
  },
];

const processSteps = [
  {
    phase: "Enquiry",
    timing: "1 business day",
    copy: "Send the sign type, rough size, site location, photos, artwork, and timing needs.",
  },
  {
    phase: "Scope and quote",
    timing: "After site details",
    copy: "Confirm materials, install assumptions, access, power needs, and any survey or approval steps.",
  },
  {
    phase: "Build and install",
    timing: "Typically a few weeks",
    copy: "Fabricate the cabinet and sign face, install on site, test illumination, and hand over aftercare notes.",
  },
];

const boundaryColumns = [
  {
    title: "Handled in the scope",
    items: [
      "Sign type, size, face, cabinet, and finish recommendations",
      "Fabrication, installation planning, illumination testing, and handover notes",
      "Written assumptions for access, artwork, support, and site conditions",
    ],
  },
  {
    title: "Confirmed before quote",
    items: [
      "Photos, rough dimensions, suburb, wall or fascia position, and timing",
      "Artwork readiness, logo quality, power availability, and cable paths",
      "Access equipment, travel, site hours, and installation restrictions",
    ],
  },
  {
    title: "May need others",
    items: [
      "Landlord, shopping centre, strata, heritage, or council approval",
      "Qualified electrical trade confirmation where connection work is required",
      "Customer approval of final artwork, production proof, and tenancy rules",
    ],
  },
];

const identityRows = [
  ["Business", businessName],
  ["Coverage", serviceArea],
  ["Response", "Quote response within 1 business day"],
  ["Quote path", "Design, fabricate, install"],
  ...(contactPhone ? [["Phone", contactPhone]] : []),
  ...(contactEmail ? [["Email", contactEmail]] : []),
  ...(businessAbn ? [["ABN", businessAbn]] : []),
];

const trustItems = [
  {
    title: "Quote assumptions should be visible",
    copy: "The quote should state size, materials, installation assumptions, artwork status, and support terms before the job moves into fabrication.",
  },
  {
    title: "Site details drive the recommendation",
    copy: "Brightness, face material, cabinet depth, mounting, and access are scoped around the actual location.",
  },
  {
    title: "Installation and handover are included",
    copy: "Installed signs are checked for illumination, face fit, fixings, service access, and aftercare guidance.",
  },
];

const quotePrepItems = [
  "Site or shopfront photos",
  "Rough width and height",
  "Logo, artwork, or brand files",
  "Suburb, site type, and sign position",
  "Power, access, timing, and approval notes",
];

const faqs = [
  {
    question: "What lightbox sign types do you make?",
    answer:
      "Common projects include shopfront fascia signs, wall-mounted cabinets, indoor reception signs, retail interior lightboxes, menu lightboxes, and commercial tenancy signage.",
  },
  {
    question: "Can I ask for a quote before the dimensions are final?",
    answer:
      "Yes. A rough size, site photos, business location, indoor or outdoor use, and logo file are enough to start the scope conversation.",
  },
  {
    question: "Do you handle installation?",
    answer:
      "Yes. The project path can include site survey, design coordination, fabrication, installation, testing, and handover across Perth and regional WA sites.",
  },
  {
    question: "How long does a custom lightbox usually take?",
    answer:
      "Straightforward jobs commonly move from scope to install over a few weeks after artwork, survey, access, and approvals are confirmed.",
  },
  {
    question: "What if I also need a fuel price board?",
    answer:
      "Fuel price boards are a specialist signage branch because they add roadside LED digit modules, operator controls, and FuelWatch-ready requirements.",
  },
];

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Custom commercial lightbox signs for WA businesses",
  description,
  serviceType:
    "Commercial lightbox sign design, fabrication, installation, testing, and aftercare",
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Western Australia",
  },
  provider: {
    "@type": "LocalBusiness",
    name: businessName || companyName,
    url: siteUrl,
    areaServed: serviceArea,
    ...(contactPhone ? { telephone: contactPhone } : {}),
    ...(contactEmail ? { email: contactEmail } : {}),
    ...(businessAbn ? { identifier: businessAbn } : {}),
  },
  url: siteUrl,
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  openGraphTitle={title}
  openGraphDescription={description}
  openGraphUrl="/"
>
  <main>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(serviceJsonLd)}
    />
    <a
      id="quote-fab"
      data-quote-fab
      href="#quote"
      aria-label="Jump to quote form"
      class="quote-fab fixed z-40 inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-amber-500 px-4 py-3 text-sm font-bold text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.16),0_18px_42px_rgba(242,163,58,0.34)] transition-[background-color,box-shadow,opacity,scale,transform] hover:bg-amber-400 active:scale-[0.96] focus:outline-none focus:ring-4 focus:ring-amber-300/45"
    >
      <span>Get quote</span>
      <Send className="h-4 w-4" aria-hidden="true" />
    </a>

    <section
      class="relative isolate flex min-h-[86svh] items-center overflow-hidden bg-stone-950 px-4 py-24 text-white"
    >
      <picture class="absolute inset-0 block h-full w-full">
        <source
          media="(max-width: 767px)"
          srcset="/images/commercial-lightbox-hero-mobile.avif"
          type="image/avif"
        />
        <source
          media="(max-width: 767px)"
          srcset="/images/commercial-lightbox-hero-mobile.webp"
          type="image/webp"
        />
        <source
          srcset="/images/commercial-lightbox-hero-desktop.avif"
          type="image/avif"
        />
        <source
          srcset="/images/commercial-lightbox-hero-desktop.webp"
          type="image/webp"
        />
        <img
          src="/images/commercial-lightbox-hero.png"
          alt="Rendered illuminated commercial lightbox sign concept for a modern shopfront"
          width="1672"
          height="941"
          fetchpriority="high"
          decoding="async"
          class="h-full w-full object-cover object-[58%_center] outline outline-1 -outline-offset-1 outline-white/10"
        />
      </picture>
      <div
        class="absolute inset-0 bg-[linear-gradient(90deg,rgba(12,10,9,0.96)_0%,rgba(12,10,9,0.82)_36%,rgba(12,10,9,0.35)_68%,rgba(12,10,9,0.08)_100%)]"
      >
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,10,9,0.14)_0%,rgba(12,10,9,0.03)_48%,rgba(12,10,9,0.74)_100%)]"
      >
      </div>

      <header class="absolute top-0 right-0 left-0 z-20 px-4 py-5">
        <nav
          class="mx-auto flex max-w-6xl items-center justify-between"
          aria-label="Primary"
        >
          <a href="/" class="text-sm font-bold tracking-wide text-white">
            {siteName}
          </a>
          <div class="flex items-center gap-4 text-sm font-semibold text-white/78">
            <a
              href="#services"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Services
            </a>
            <a
              href="#price-guidance"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Pricing
            </a>
            <a
              href="#process"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Process
            </a>
            <a
              href="/preview"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Preview
            </a>
            {
              contactPhone && (
                <a
                  href={phoneHref(contactPhone)}
                  class="hidden min-h-10 items-center rounded-lg bg-white/10 px-3 py-2 text-white shadow-[0_0_0_1px_rgba(255,255,255,0.14)] transition-[background-color,scale] hover:bg-white/15 active:scale-[0.96] lg:inline-flex"
                >
                  Call {contactPhone}
                </a>
              )
            }
            <a
              href="#quote"
              class="inline-flex min-h-10 items-center rounded-lg bg-white px-4 py-2 text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.1)] transition-[background-color,scale] hover:bg-amber-100 active:scale-[0.96]"
            >
              Request quote
            </a>
          </div>
        </nav>
      </header>

      <div class="relative z-10 mx-auto w-full max-w-6xl pt-12">
        <div class="max-w-3xl" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-200">
            Custom illuminated signage in WA
          </p>
          <h1
            class="mt-5 text-balance text-5xl font-semibold leading-[1.02] tracking-normal text-white sm:text-6xl lg:text-7xl"
          >
            Custom lightbox signs for WA businesses
          </h1>
          <p class="mt-6 max-w-2xl text-pretty text-lg leading-8 text-white/82">
            Indoor, shopfront, menu, fascia, and outdoor lightboxes scoped,
            fabricated, and installed across Perth and regional WA.
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a
              href="#quote"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-amber-500 px-6 py-3 text-sm font-bold text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.12),0_16px_36px_rgba(242,163,58,0.28)] transition-[background-color,scale,box-shadow] hover:bg-amber-400 active:scale-[0.96]"
            >
              Request a quote
            </a>
            <a
              href="/preview"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-white/10 px-6 py-3 text-sm font-bold text-white shadow-[0_0_0_1px_rgba(255,255,255,0.18)] transition-[background-color,scale,box-shadow] hover:bg-white/15 active:scale-[0.96]"
            >
              Preview your sign
            </a>
          </div>
          {
            contactLinks.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-3 text-sm font-semibold text-white/82">
                {contactLinks.map((link) => (
                  <a
                    href={link.href}
                    class="inline-flex min-h-10 items-center rounded-lg bg-white/[0.08] px-3 py-2 shadow-[0_0_0_1px_rgba(255,255,255,0.14)] transition-[background-color,scale] hover:bg-white/[0.13] hover:text-white active:scale-[0.96]"
                  >
                    {link.label}: {link.value}
                  </a>
                ))}
              </div>
            )
          }
        </div>
        <dl
          class="mt-12 grid gap-3 sm:grid-cols-3"
          data-reveal
          data-reveal-delay="1"
        >
          {
            heroHighlights.map(([label, value]) => (
              <div class="rounded-lg bg-white/[0.08] p-4 shadow-[0_0_0_1px_rgba(255,255,255,0.14)]">
                <dt class="text-xs font-bold uppercase tracking-[0.16em] text-amber-200">
                  {label}
                </dt>
                <dd class="mt-2 text-sm leading-6 text-white/82">{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section
      id="examples"
      class="bg-white px-4 py-20 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="Example project scopes"
            title="The kind of evidence future real case studies should show."
            copy="These are illustrative examples using placeholder images. Replace them with owned project photos when real customer work can be shown publicly."
          />
        </div>
        <div class="mt-12 grid gap-5 lg:grid-cols-3">
          {
            exampleProjects.map((item, index) => (
              <article
                class="overflow-hidden rounded-lg bg-stone-50 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_16px_42px_rgba(0,0,0,0.07)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  loading="lazy"
                  decoding="async"
                  width="1536"
                  height="1024"
                  class="aspect-[16/10] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
                />
                <div class="p-6">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-amber-700">
                    Illustrative example
                  </p>
                  <h3 class="mt-3 text-xl font-semibold text-stone-950">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                    {item.scope}
                  </p>
                  <ul class="mt-5 divide-y divide-stone-200 text-sm leading-6 text-stone-700">
                    {item.details.map((detail) => (
                      <li class="py-2 first:pt-0 last:pb-0">
                        {detail}
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="price-guidance" class="bg-[#f3efe7] px-4 py-20">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div data-reveal>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-800">
            Price guidance
          </p>
          <h2 class="mt-3 text-balance text-3xl font-semibold md:text-4xl">
            A useful pricing conversation starts with site details, not a
            made-up size chart.
          </h2>
          <p class="mt-5 text-pretty text-lg leading-8 text-stone-600">
            We are not publishing unverified starting prices here. Instead, the
            first reply should give a practical range or the exact scope
            questions needed to prepare a written quote.
          </p>
        </div>
        <div class="grid gap-4">
          {
            priceGuidance.map((item, index) => (
              <article
                class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_36px_rgba(0,0,0,0.06)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <h3 class="text-xl font-semibold text-stone-950">
                  {item.title}
                </h3>
                <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                  {item.copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="services"
      class="bg-stone-50 px-4 py-20 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="What we make"
            title="The common lightbox jobs customers ask about first."
            copy="Choose the closest sign type to see the details. The quote can still combine indoor, outdoor, menu, and shopfront requirements."
          />
        </div>
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            serviceCards.map((item, index) => (
              <a
                href={item.href}
                class="group block overflow-hidden rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_42px_rgba(0,0,0,0.07)] transition-[box-shadow,scale] hover:scale-[1.01] hover:shadow-[0_0_0_1px_rgba(15,118,110,0.18),0_18px_48px_rgba(0,0,0,0.1)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  loading="lazy"
                  decoding="async"
                  width="1536"
                  height="1024"
                  class="aspect-[16/10] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
                />
                <div class="p-6">
                  <h3 class="text-lg font-semibold text-stone-950">
                    {item.title}
                  </h3>
                  <p class="mt-4 text-pretty text-sm leading-7 text-stone-600">
                    {item.copy}
                  </p>
                  <p class="mt-5 text-sm font-bold text-teal-800 underline decoration-teal-700/35 underline-offset-4 group-hover:text-stone-950 group-hover:decoration-stone-950">
                    Learn more
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="quote-factors" class="bg-white px-4 py-20">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
        <div class="grid gap-8" data-reveal>
          <SectionHeader
            kicker="What affects the quote"
            title="A useful price starts with the site, not a generic size chart."
            copy="The same lightbox can quote differently when visibility, mounting, exposure, access, artwork, or power changes."
          />
          <picture class="block overflow-hidden rounded-lg bg-stone-100 shadow-[0_0_0_1px_rgba(0,0,0,0.08),0_14px_38px_rgba(0,0,0,0.09)]">
            <img
              src={placeholderImages.detail.src}
              alt={placeholderImages.detail.alt}
              loading="lazy"
              decoding="async"
              width="1536"
              height="1024"
              class="aspect-[16/10] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
            />
          </picture>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            quoteFactors.map((factor, index) => (
              <article
                class="rounded-lg bg-stone-50 p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_12px_32px_rgba(0,0,0,0.05)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <h3 class="text-xl font-semibold text-stone-950">
                  {factor.title}
                </h3>
                <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                  {factor.copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="materials" class="bg-stone-50 px-4 py-20">
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="Materials and support"
            title="The cabinet, face, lighting, warranty, and maintenance path should be written down."
            copy="Specific warranty terms and exclusions belong in the written quote. This section explains the details customers should expect to see confirmed before fabrication."
          />
        </div>
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            materialCareItems.map((item, index) => (
              <article
                class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_36px_rgba(0,0,0,0.06)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <h3 class="text-lg font-semibold text-stone-950">
                  {item.title}
