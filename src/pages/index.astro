      >
      </div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-56 bg-[linear-gradient(180deg,rgba(255,247,235,0)_0%,rgba(255,247,235,0.72)_100%)]"
