    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(180deg,#ffffff_0%,#fffdf8_15%,#fbf0df_48%,#f3dfc1_100%)]"
      >
      </div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-44 bg-[linear-gradient(180deg,#ffffff_0%,rgba(255,255,255,0.78)_42%,rgba(255,255,255,0)_100%)]"
      >
      </div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(116deg,rgba(242,163,58,0.22)_0%,rgba(242,163,58,0.1)_34%,rgba(242,163,58,0)_62%),linear-gradient(247deg,rgba(15,118,110,0.12)_0%,rgba(15,118,110,0)_44%)]"
