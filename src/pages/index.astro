---
import SectionHeader from "../components/SectionHeader.astro";
import QuoteForm from "../components/QuoteForm";
import BaseLayout from "../layouts/BaseLayout.astro";
import { companyName, fuelPriceBoardUrl, siteName, siteUrl } from "../lib/site";

const title = "Commercial Lightbox | Custom Lightbox Signs in WA";
const description =
  "Indoor and outdoor advertising lightboxes in WA, with survey, design, fabrication, installation, and testing for commercial signage projects.";

const applications = [
  {
    title: "Indoor food courts",
    copy: "Menu, counter, and tenancy lightboxes with comfortable brightness, tidy indoor mounting, and easy-clean sign faces.",
  },
  {
    title: "Retail interiors",
    copy: "Reception, wall, and product-area lightboxes that make brand signage clear without overpowering the space.",
  },
  {
    title: "Outdoor shopfronts",
    copy: "Illuminated fascia signs and wall-mounted lightboxes built around weather exposure, access, structure, and night visibility.",
  },
  {
    title: "Service stations",
    copy: "Outdoor illuminated signage and fuel price display deployment for forecourts, roadside visibility, and site testing.",
  },
];

const capabilityGroups = [
  {
    label: "Indoor",
    title: "Food courts, counters, menus, and reception lightboxes.",
    copy: "Indoor advertising lightboxes need controlled brightness, clean face materials, low-heat LED systems, and mounting that works with ceilings, counters, tenancy walls, and shopfit-out details.",
    points: [
      "Comfortable light levels for close viewing",
      "Easy-clean acrylic or polycarbonate sign faces",
      "Tidy indoor mounting and cable paths",
    ],
  },
  {
    label: "Outdoor",
    title: "Shopfronts, service stations, and fuel retail displays.",
    copy: "Outdoor projects need weather-aware cabinets, structural fixing, readable viewing distance, power/control coordination, and final testing on site before handover.",
    points: [
      "Weather-aware construction and service access",
      "Visibility planned around road and pedestrian angles",
      "Deployment, power coordination, and site testing",
    ],
  },
];

const siteExamples = [
  {
    location: "Maddington",
    title: "Indoor food court advertising lightbox",
    type: "Indoor",
    copy: "A food court signage project where the lightbox needed to sit cleanly within the indoor retail environment and remain readable at close range.",
    scope: "Site check, design coordination, fabrication, installation",
  },
  {
    location: "Maddington",
    title: "Service station fuel price display",
    type: "Outdoor",
    copy: "A fuel retail display project focused on roadside readability, outdoor deployment, and testing for the service station environment.",
    scope: "Site survey, display specification, deployment, testing",
  },
];

const processSteps = [
  [
    "1",
    "Survey",
    "Measure the site and confirm mounting, exposure, power, access, and permit needs.",
  ],
  [
    "2",
    "Design",
    "Resolve artwork, light spread, face material, cabinet depth, and service access.",
  ],
  [
    "3",
    "Build",
    "Fabricate the frame, LED system, diffuser, display hardware, and branded sign face.",
  ],
  [
    "4",
    "Deploy & test",
    "Install on site, coordinate power, test visibility and operation, then hand over.",
  ],
];

const materialNotes = [
  "Acrylic or polycarbonate faces selected for indoor cleaning, outdoor impact, UV exposure, and light diffusion.",
  "Powder-coated aluminium cabinets with serviceable LED modules, tidy cable routing, and low-heat operation.",
  "Weather-aware mounting details for WA shopfronts, service stations, coastal strips, and exposed roadsides.",
];

const faqs = [
  {
    question: "Do you make both indoor and outdoor advertising lightboxes?",
    answer:
      "Yes. Indoor projects include food courts, counters, menus, reception areas, and retail interiors. Outdoor projects include shopfronts, wall-mounted lightboxes, service station signage, and fuel price displays.",
  },
  {
    question: "Can you work from an existing logo file?",
    answer:
      "Yes. Vector artwork is ideal, but we can also advise what needs to be redrawn before manufacturing a clean illuminated sign face.",
  },
  {
    question: "Do you handle installation?",
    answer:
      "Yes. The quote can include site survey, design coordination, fabrication, installation, power coordination, testing, and handover for Perth and regional WA sites.",
  },
  {
    question: "Can the lightbox be outdoor rated?",
    answer:
      "Yes. Cabinet depth, seals, drainage, face material, and LED access are selected around the installation position.",
  },
  {
    question: "What if I also need a fuel price board?",
    answer:
      "Fuel price boards are handled as a specialist roadside LED display path, with FuelWatch-ready options for WA service stations.",
  },
];

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Custom commercial lightbox signage",
  description,
  serviceType:
    "Indoor and outdoor advertising lightbox design, fabrication, installation, and testing",
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Western Australia",
  },
  provider: {
    "@type": "LocalBusiness",
    name: companyName,
    url: siteUrl,
    areaServed: "Western Australia",
  },
  url: siteUrl,
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  openGraphTitle={title}
  openGraphDescription={description}
  openGraphUrl="/"
>
  <main>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(serviceJsonLd)}
    />
    <section
      class="relative isolate flex min-h-[88svh] items-center overflow-hidden bg-stone-950 px-4 py-24 text-white"
    >
      <img
        src="/images/commercial-lightbox-hero.png"
        alt="Illuminated custom commercial lightbox sign on a modern shopfront"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover object-[58%_center]"
      />
      <div
        class="absolute inset-0 bg-[linear-gradient(90deg,rgba(12,10,9,0.96)_0%,rgba(12,10,9,0.82)_36%,rgba(12,10,9,0.35)_68%,rgba(12,10,9,0.08)_100%)]"
      >
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,10,9,0.14)_0%,rgba(12,10,9,0.03)_48%,rgba(12,10,9,0.74)_100%)]"
      >
      </div>

      <header class="absolute top-0 right-0 left-0 z-20 px-4 py-5">
        <nav
          class="mx-auto flex max-w-6xl items-center justify-between"
          aria-label="Primary"
        >
          <a href="/" class="text-sm font-bold tracking-wide text-white">
            {siteName}
          </a>
          <div class="flex items-center gap-4 text-sm font-semibold text-white/78">
            <a
              href="#applications"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Applications
            </a>
            <a
              href="#site-examples"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Examples
            </a>
            <a
              href="/preview"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Preview
            </a>
            <a
              href="#quote"
              class="inline-flex min-h-10 items-center rounded-lg bg-white px-4 py-2 text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.1)] transition-[background-color,scale] hover:bg-amber-100 active:scale-[0.96]"
            >
              Request quote
            </a>
          </div>
        </nav>
      </header>

      <div class="relative z-10 mx-auto w-full max-w-6xl pt-12">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-200">
            Custom illuminated signage in WA
          </p>
          <h1
            class="mt-5 text-balance text-5xl font-semibold leading-[1.02] tracking-normal text-white sm:text-6xl lg:text-7xl"
          >
            Commercial Lightbox
          </h1>
          <p class="mt-6 max-w-xl text-pretty text-lg leading-8 text-white/82">
            Indoor and outdoor advertising lightboxes with survey, design,
            fabrication, installation, and testing for food courts, shopfronts,
            service stations, and commercial sites.
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a
              href="#quote"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-amber-500 px-6 py-3 text-sm font-bold text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.12),0_16px_36px_rgba(242,163,58,0.28)] transition-[background-color,scale,box-shadow] hover:bg-amber-400 active:scale-[0.96]"
            >
              Get a custom quote
            </a>
            <a
              href="/case-studies/fuel-price-boards"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-white/10 px-6 py-3 text-sm font-bold text-white shadow-[0_0_0_1px_rgba(255,255,255,0.18)] transition-[background-color,scale,box-shadow] hover:bg-white/15 active:scale-[0.96]"
            >
              View signage case study
            </a>
            <a
              href="/preview"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-white/10 px-6 py-3 text-sm font-bold text-white shadow-[0_0_0_1px_rgba(255,255,255,0.18)] transition-[background-color,scale,box-shadow] hover:bg-white/15 active:scale-[0.96]"
            >
              Try preview tool
            </a>
          </div>
        </div>
      </div>
    </section>

    <section
      id="applications"
      class="bg-stone-50 px-4 py-20 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <div class="mx-auto max-w-6xl">
        <SectionHeader
          kicker="Applications"
          title="Indoor comfort and outdoor visibility need different details."
          copy="Every lightbox starts with the place it needs to work: viewing distance, brightness, wall structure, brand artwork, power, weather, and maintenance access."
        />
        <div class="mt-12 grid gap-5 md:grid-cols-4">
          {
            applications.map((item) => (
              <article class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_42px_rgba(0,0,0,0.07)]">
                <h3 class="text-lg font-semibold text-stone-950">
                  {item.title}
                </h3>
                <p class="mt-4 text-pretty text-sm leading-7 text-stone-600">
                  {item.copy}
                </p>
                {item.title === "Service stations" && (
                  <a
                    href={`${fuelPriceBoardUrl}/products/fuel-price-board`}
                    class="mt-5 inline-flex min-h-10 items-center text-sm font-bold text-teal-800 underline decoration-teal-700/35 underline-offset-4 transition-[color,text-decoration-color] hover:text-stone-950 hover:decoration-stone-950"
                  >
                    FuelWatch-ready LED fuel price boards
                  </a>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white px-4 py-20">
      <div class="mx-auto max-w-6xl">
        <SectionHeader
          kicker="Indoor + outdoor"
          title="Advertising lightboxes for controlled interiors and exposed sites."
          copy="The same one-stop service adapts to the environment: indoor projects need clean finishes and comfortable illumination, while outdoor projects need structure, weather detail, distance visibility, and site testing."
        />
        <div class="mt-12 grid gap-5 lg:grid-cols-2">
          {
            capabilityGroups.map((group) => (
              <article class="rounded-lg bg-stone-50 p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_38px_rgba(0,0,0,0.06)] sm:p-7">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-800">
                  {group.label}
                </p>
                <h3 class="mt-3 text-balance text-2xl font-semibold text-stone-950">
                  {group.title}
                </h3>
                <p class="mt-4 text-pretty leading-7 text-stone-600">
                  {group.copy}
                </p>
                <ul class="mt-6 grid gap-3">
                  {group.points.map((point) => (
                    <li class="rounded-lg bg-white px-4 py-3 text-sm font-semibold text-stone-700 shadow-[0_0_0_1px_rgba(0,0,0,0.06)]">
                      {point}
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="site-examples"
      class="bg-[#f3efe7] px-4 py-20 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-800">
            Site examples
          </p>
          <h2
            class="mt-3 text-balance text-3xl font-semibold text-stone-950 md:text-4xl"
          >
            Maddington projects show both sides of the capability.
          </h2>
          <p class="mt-5 text-pretty text-lg leading-8 text-stone-600">
            These examples are shared at suburb and project-type level only.
            They show the range from indoor food court advertising lightboxes to
            outdoor fuel retail display deployment.
          </p>
        </div>
        <div class="grid gap-5">
          {
            siteExamples.map((example) => (
              <article class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_16px_42px_rgba(0,0,0,0.08)]">
                <div class="flex flex-wrap items-center gap-3">
                  <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-amber-700">
                    {example.location}
                  </p>
                  <p class="rounded-md bg-stone-100 px-3 py-1 text-xs font-bold text-stone-700">
                    {example.type}
                  </p>
                </div>
                <h3 class="mt-4 text-xl font-semibold text-stone-950">
                  {example.title}
                </h3>
                <p class="mt-3 text-pretty leading-7 text-stone-600">
                  {example.copy}
                </p>
                <p class="mt-5 rounded-lg bg-stone-50 px-4 py-3 text-sm font-semibold leading-6 text-stone-700 shadow-[0_0_0_1px_rgba(0,0,0,0.06)]">
                  Scope: {example.scope}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white px-4 py-20">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <SectionHeader
          kicker="Process"
          title="A practical route from artwork to deployed signage."
          copy="The job stays grounded in the details that affect the finished result: site measurement, legibility, brightness, cabinet depth, weather exposure, power coordination, and final testing."
        />
        <div class="grid gap-4 sm:grid-cols-2">
          {
            processSteps.map(([number, stepTitle, copy]) => (
              <article class="rounded-lg bg-stone-50 p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_12px_32px_rgba(0,0,0,0.05)]">
                <p class="font-mono text-sm font-semibold tabular-nums text-amber-700">
                  {number}
                </p>
                <h3 class="mt-4 text-xl font-semibold text-stone-950">
                  {stepTitle}
                </h3>
                <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                  {copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-stone-950 px-4 py-20 text-white">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-300">
            Materials
          </p>
          <h2 class="mt-3 text-balance text-3xl font-semibold md:text-4xl">
            Bright at night, clean in daylight, serviceable after deployment.
          </h2>
        </div>
        <ul class="grid gap-4">
          {
            materialNotes.map((note) => (
              <li class="rounded-lg bg-white/[0.06] p-5 text-pretty leading-7 text-white/78 shadow-[0_0_0_1px_rgba(255,255,255,0.1)]">
                {note}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="bg-[#f3efe7] px-4 py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-800">
            Case study
          </p>
          <h2
            class="mt-3 text-balance text-3xl font-semibold text-stone-950 md:text-4xl"
          >
            From custom lightboxes to specialist fuel price displays.
          </h2>
          <p class="mt-5 text-pretty text-lg leading-8 text-stone-600">
            Fuel price signage is a focused branch of illuminated roadside
            display work. For service stations, the dedicated FuelWatch-ready
            product path gives owners a clearer way to compare board formats.
          </p>
        </div>
        <div
          class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_18px_48px_rgba(0,0,0,0.1)]"
        >
          <h3 class="text-2xl font-semibold text-stone-950">
            Fuel price board customer path
          </h3>
          <p class="mt-4 text-pretty leading-7 text-stone-600">
            See how the signage capability narrows into weather-rated,
            high-brightness roadside LED displays for petrol station pricing.
          </p>
          <a
            href="/case-studies/fuel-price-boards"
            class="mt-6 inline-flex min-h-11 items-center rounded-lg bg-stone-950 px-5 py-3 text-sm font-bold text-white shadow-[0_1px_2px_rgba(0,0,0,0.12)] transition-[background-color,scale] hover:bg-teal-800 active:scale-[0.96]"
          >
            Read the case study
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white px-4 py-20">
      <div class="mx-auto max-w-6xl">
        <SectionHeader
          kicker="Questions"
          title="Useful answers before you request pricing."
          copy="Quotes vary with size, mounting, access, face material, installation travel, and any permit or artwork preparation needed."
        />
        <div class="mt-12 grid gap-5 md:grid-cols-2">
          {
            faqs.map((faq) => (
              <article class="rounded-lg bg-stone-50 p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_12px_32px_rgba(0,0,0,0.05)]">
                <h3 class="text-lg font-semibold text-stone-950">
                  {faq.question}
                </h3>
                <p class="mt-3 text-pretty leading-7 text-stone-600">
                  {faq.answer}
                </p>
                {faq.question === "What if I also need a fuel price board?" && (
                  <a
                    href={`${fuelPriceBoardUrl}/products/fuel-price-board`}
                    class="mt-5 inline-flex min-h-10 items-center text-sm font-bold text-teal-800 underline decoration-teal-700/35 underline-offset-4 transition-[color,text-decoration-color] hover:text-stone-950 hover:decoration-stone-950"
                  >
                    View the fuel price board range
                  </a>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="quote" class="bg-stone-950 px-4 py-20 text-white">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-300">
            Quote
          </p>
          <h2 class="mt-3 text-balance text-3xl font-semibold md:text-4xl">
            Share the site details and we will scope the sign.
          </h2>
          <p class="mt-5 text-pretty text-lg leading-8 text-white/72">
            Send the rough size, location, indoor or outdoor sign type, and any
            timing needs. If you are not sure about dimensions yet, we can start
            from the site position and installation conditions.
          </p>
          <dl class="mt-9 grid gap-4 text-sm text-white/75">
            {
              [
                ["Response", "1 business day"],
                ["Coverage", "Perth + regional WA"],
                ["Path", "Survey, design, deploy"],
              ].map(([label, value]) => (
                <div class="border-l border-amber-400 pl-4">
                  <dt class="font-mono text-xs uppercase tracking-[0.16em] text-amber-300">
                    {label}
                  </dt>
                  <dd class="mt-1 text-white">{value}</dd>
                </div>
              ))
            }
          </dl>
        </div>
        <div
          class="rounded-lg bg-white p-6 text-stone-950 shadow-[0_0_0_1px_rgba(255,255,255,0.12),0_24px_70px_rgba(0,0,0,0.35)] sm:p-8"
        >
          <QuoteForm client:load />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
