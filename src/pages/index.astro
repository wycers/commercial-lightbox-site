          <div class="mt-8 rounded-lg bg-white/72 p-5 shadow-[inset_3px_0_0_rgba(15,118,110,0.42),0_0_0_1px_rgba(255,255,255,0.78),0_1px_2px_rgba(0,0,0,0.04),0_18px_42px_rgba(92,59,19,0.08)] backdrop-blur">
