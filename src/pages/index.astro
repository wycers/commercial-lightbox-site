---
import SectionHeader from "../components/SectionHeader.astro";
import QuoteForm from "../components/QuoteForm";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Send } from "lucide-react";
import {
  businessAbn,
  businessName,
  companyName,
  contactEmail,
  contactPhone,
  emailHref,
  fuelPriceBoardUrl,
  phoneHref,
  serviceArea,
  siteName,
  siteUrl,
} from "../lib/site";

const title = "Custom Commercial Lightbox Signs for WA Businesses";
const description =
  "Custom commercial lightbox signs for WA businesses, with site survey, design coordination, fabrication, installation, testing, and aftercare.";

const heroHighlights = [
  ["WA focus", `${serviceArea} site scoping`],
  ["Project path", "Survey, design, fabricate, install"],
  ["Sign types", "Indoor, shopfront, fascia, wall-mounted"],
  [
    "Response",
    contactPhone || contactEmail
      ? "Quote form, phone, or email"
      : "Quote form with 1 business day reply",
  ],
];

const contactLinks = [
  contactPhone
    ? {
        label: "Call",
        value: contactPhone,
        href: phoneHref(contactPhone),
      }
    : null,
  contactEmail
    ? {
        label: "Email",
        value: contactEmail,
        href: emailHref(contactEmail),
      }
    : null,
].filter(Boolean) as Array<{ label: string; value: string; href: string }>;

const placeholderImages = {
  shopfront: {
    src: "/images/commercial-lightbox-shopfront-placeholder.png",
    alt: "Blank illuminated shopfront lightbox sign placeholder on a modern commercial frontage",
  },
  indoor: {
    src: "/images/commercial-lightbox-indoor-placeholder.png",
    alt: "Blank indoor commercial lightbox panel placeholder in a reception setting",
  },
  detail: {
    src: "/images/commercial-lightbox-detail-placeholder.png",
    alt: "Commercial lightbox cabinet detail placeholder showing diffuser, LEDs, and aluminium housing",
  },
};

const identityRows = [
  ["Business", businessName],
  ["Coverage", serviceArea],
  ...(businessAbn ? [["ABN", businessAbn]] : []),
];

const applications = [
  {
    title: "Shopfront lightbox signs",
    copy: "Fascia, wall-mounted, and window-facing signs planned around distance, structure, access, and night visibility.",
  },
  {
    title: "Retail interiors",
    copy: "Reception, brand wall, and product-area lightboxes with clean finishes and comfortable brightness.",
  },
  {
    title: "Food courts and menus",
    copy: "Menu, counter, and tenancy lightboxes that stay readable up close without overpowering seating or queues.",
  },
  {
    title: "Commercial tenancy signs",
    copy: "Purpose-built illuminated signage for offices, clinics, gyms, showrooms, and mixed-use WA sites.",
  },
];

const capabilityGroups = [
  {
    label: "Indoor",
    title: "Controlled light for close viewing and tidy fit-outs.",
    copy: "Indoor lightboxes need soft diffusion, easy-clean faces, low-heat LEDs, and mounting that respects the fit-out.",
    image: placeholderImages.indoor,
    points: [
      "Comfortable brightness for staff and customers",
      "Acrylic or polycarbonate faces selected for cleaning and diffusion",
      "Concealed fixing and cable paths where site conditions allow",
    ],
  },
  {
    label: "Outdoor",
    title: "Weather-aware signage for shopfronts and exposed walls.",
    copy: "Outdoor lightboxes need cabinet depth, drainage, access, fixing detail, viewing angles, and power coordination.",
    image: placeholderImages.shopfront,
    points: [
      "Materials chosen around UV, exposure, impact, and access",
      "Viewing distance checked for pedestrians, traffic, and site approach",
      "Installation and final testing included in the project path",
    ],
  },
];

const trustAnchors = [
  {
    label: "Scope clarity",
    title: "A quote tied to the actual site.",
    copy: "Pricing follows sign size, mounting, access, artwork, power coordination, and indoor or outdoor use.",
  },
  {
    label: "Material choices",
    title: "The spec explains what is being built.",
    copy: "Face material, cabinet finish, LED layout, service access, and install assumptions are documented first.",
  },
  {
    label: "Business details",
    title: "Practical ways to verify the scope.",
    copy: "Contact details, business identity, project notes, and quote terms can be published once confirmed.",
  },
  {
    label: "Handover",
    title: "Installed signs are checked before sign-off.",
    copy: "Handover covers illumination, face fit, fixings, service access notes, and aftercare guidance.",
  },
];

const specRows = [
  [
    "Common formats",
    "Shopfront fascia, wall-mounted cabinets, food court menus, reception signs, and retail interior lightboxes.",
  ],
  [
    "Face materials",
    "Opal acrylic or polycarbonate selected around diffusion, cleaning, impact, UV exposure, and replacement access.",
  ],
  [
    "Cabinet build",
    "Powder-coated aluminium cabinets with service access planned around the mounting position and site constraints.",
  ],
  [
    "Illumination",
    "LED modules laid out for even light spread, with brightness matched to indoor comfort or outdoor visibility.",
  ],
  [
    "Artwork",
    "Vector files are preferred; lower-resolution logos can be reviewed for redraw needs before manufacturing.",
  ],
  [
    "Installation",
    "Fixing method, access equipment, cable paths, switching, and any permit dependencies are confirmed during scope.",
  ],
];

const timelineSteps = [
  {
    phase: "Initial scope",
    timing: "1-2 business days",
    copy: "Review sign type, rough size, location, photos, artwork, access, and timing.",
  },
  {
    phase: "Survey and specification",
    timing: "2-5 business days",
    copy: "Measure the site, check mounting and power, then confirm materials and install needs.",
  },
  {
    phase: "Design approval",
    timing: "3-7 business days",
    copy: "Resolve artwork, layout, face details, cabinet depth, brightness, and approval notes.",
  },
  {
    phase: "Fabrication",
    timing: "Typically 2-4 weeks",
    copy: "Build the cabinet, LED system, diffuser, sign face, and any project-specific mounting details.",
  },
  {
    phase: "Install and handover",
    timing: "Often 1 site day",
    copy: "Install, coordinate power where required, test illumination, and document aftercare before sign-off.",
  },
];

const aftercarePoints = [
  {
    title: "Warranty stated in the quote",
    copy: "Warranty length, inclusions, exclusions, and component terms should be written into the final quote.",
  },
  {
    title: "Serviceable parts",
    copy: "Cabinets and LED layouts are planned so faces, modules, and access points can be serviced.",
  },
  {
    title: "Post-install support",
    copy: "After handover, support can cover brightness checks, face replacement, LED servicing, and rebrand advice.",
  },
];

const caseCards = [
  {
    badge: "Scope example",
    setting: "Indoor retail tenancy",
    title: "Food court counter lightbox",
    challenge:
      "Close-range menu signage needs even light, clean edges, and glare control.",
    approach:
      "Specify a shallow cabinet, opal face, serviceable LED layout, and tenancy-wall install details.",
    deliverables: [
      "Site measure",
      "Artwork sizing",
      "Cabinet fabrication",
      "Install and light test",
    ],
    note: "Useful for food venues comparing cabinet depth, glare, cleaning, and menu legibility.",
  },
  {
    badge: "Scope example",
    setting: "Outdoor shopfront",
    title: "Weather-aware fascia sign",
    challenge:
      "A street-facing sign must stay readable at night while accounting for wall structure and exposure.",
    approach:
      "Confirm fixings, cabinet depth, drainage, face material, LED spacing, and night visibility before build.",
    deliverables: [
      "Survey notes",
      "Material specification",
      "Outdoor cabinet",
      "Handover checks",
    ],
    note: "Useful for street-facing sites where wall condition, weather, and visibility affect the quote.",
  },
  {
    badge: "Scope example",
    setting: "Commercial interior",
    title: "Reception brand wall lightbox",
    challenge:
      "A reception sign should feel premium by day and stay evenly lit after hours.",
    approach:
      "Match diffusion, LED spacing, cabinet finish, switching, and cable paths to the fit-out.",
    deliverables: [
      "Artwork review",
      "Finish selection",
      "Fabrication",
      "Aftercare notes",
    ],
    note: "Useful for reception and showroom projects balancing daylight finish and after-hours glow.",
  },
];

const materialNotes = [
  "Acrylic or polycarbonate faces are selected around cleaning, impact, UV exposure, and light diffusion.",
  "Powder-coated aluminium cabinets can include serviceable LEDs, tidy cable routing, and low-heat operation.",
  "Weather-aware mounting helps WA shopfronts, coastal strips, commercial walls, and exposed sites stay maintainable.",
];

const faqs = [
  {
    question: "Do you make both indoor and outdoor commercial lightbox signs?",
    answer:
      "Yes. Indoor projects include food courts, reception areas, counters, retail interiors, and commercial tenancies. Outdoor projects include shopfront fascia signs, wall-mounted cabinets, and exposed business signage.",
  },
  {
    question: "Can you work from an existing logo file?",
    answer:
      "Yes. Vector artwork is ideal, but lower-resolution logos can be reviewed so any redraw work is clear before manufacturing a clean illuminated sign face.",
  },
  {
    question: "Do you handle installation?",
    answer:
      "Yes. The quote can include site survey, design coordination, fabrication, installation, power coordination, testing, and handover for Perth and regional WA sites.",
  },
  {
    question: "How long does a custom lightbox usually take?",
    answer:
      "A straightforward job commonly moves from scope to install over a few weeks after artwork, survey, access, and approvals are confirmed. The timeline section above shows a typical path, not a fixed promise.",
  },
  {
    question: "What warranty or aftercare is included?",
    answer:
      "Warranty terms should be stated in the final quote because they depend on the cabinet, LED components, installation environment, and supplier terms. Aftercare can include handover notes, service guidance, and support for face or LED servicing.",
  },
  {
    question: "How do you handle business details and project proof?",
    answer:
      "The site is set up to publish confirmed business details, approved contact channels, and real project proof when those assets are available. Until then, the quote process focuses on the site information needed to scope the job accurately.",
  },
  {
    question: "What if I also need a fuel price board?",
    answer:
      "Fuel price boards are handled as a specialist branch because they add roadside LED digit modules, operator controls, and FuelWatch-ready requirements beyond a standard lightbox sign.",
  },
];

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Custom commercial lightbox signs for WA businesses",
  description,
  serviceType:
    "Commercial lightbox sign design, fabrication, installation, testing, and aftercare",
  areaServed: {
    "@type": "AdministrativeArea",
    name: "Western Australia",
  },
  provider: {
    "@type": "LocalBusiness",
    name: businessName || companyName,
    url: siteUrl,
    areaServed: serviceArea,
    ...(contactPhone ? { telephone: contactPhone } : {}),
    ...(contactEmail ? { email: contactEmail } : {}),
    ...(businessAbn ? { identifier: businessAbn } : {}),
  },
  url: siteUrl,
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  openGraphTitle={title}
  openGraphDescription={description}
  openGraphUrl="/"
>
  <main>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(serviceJsonLd)}
    />
    <a
      id="quote-fab"
      data-quote-fab
      href="#quote"
      aria-label="Jump to quote form"
      class="quote-fab fixed z-40 inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-amber-500 px-4 py-3 text-sm font-bold text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.16),0_18px_42px_rgba(242,163,58,0.34)] transition-[background-color,box-shadow,opacity,scale,transform] hover:bg-amber-400 active:scale-[0.96] focus:outline-none focus:ring-4 focus:ring-amber-300/45"
    >
      <span>Get quote</span>
      <Send className="h-4 w-4" aria-hidden="true" />
    </a>
    <section
      class="relative isolate flex min-h-[88svh] items-center overflow-hidden bg-stone-950 px-4 py-24 text-white"
    >
      <picture class="absolute inset-0 block h-full w-full">
        <source
          media="(max-width: 767px)"
          srcset="/images/commercial-lightbox-hero-mobile.avif"
          type="image/avif"
        />
        <source
          media="(max-width: 767px)"
          srcset="/images/commercial-lightbox-hero-mobile.webp"
          type="image/webp"
        />
        <source
          srcset="/images/commercial-lightbox-hero-desktop.avif"
          type="image/avif"
        />
        <source
          srcset="/images/commercial-lightbox-hero-desktop.webp"
          type="image/webp"
        />
        <img
          src="/images/commercial-lightbox-hero.png"
          alt="Rendered illuminated commercial lightbox sign concept for a modern shopfront"
          width="1672"
          height="941"
          fetchpriority="high"
          decoding="async"
          class="h-full w-full object-cover object-[58%_center] outline outline-1 -outline-offset-1 outline-white/10"
        />
      </picture>
      <div
        class="absolute inset-0 bg-[linear-gradient(90deg,rgba(12,10,9,0.96)_0%,rgba(12,10,9,0.82)_36%,rgba(12,10,9,0.35)_68%,rgba(12,10,9,0.08)_100%)]"
      >
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,10,9,0.14)_0%,rgba(12,10,9,0.03)_48%,rgba(12,10,9,0.74)_100%)]"
      >
      </div>

      <header class="absolute top-0 right-0 left-0 z-20 px-4 py-5">
        <nav
          class="mx-auto flex max-w-6xl items-center justify-between"
          aria-label="Primary"
        >
          <a href="/" class="text-sm font-bold tracking-wide text-white">
            {siteName}
          </a>
          <div class="flex items-center gap-4 text-sm font-semibold text-white/78">
            <a
              href="#applications"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Applications
            </a>
            <a
              href="#specs"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Specs
            </a>
            <a
              href="#timeline"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Timeline
            </a>
            <a
              href="#case-cards"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Examples
            </a>
            <a
              href="/preview"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Preview
            </a>
            {
              contactPhone && (
                <a
                  href={phoneHref(contactPhone)}
                  class="hidden min-h-10 items-center rounded-lg bg-white/10 px-3 py-2 text-white shadow-[0_0_0_1px_rgba(255,255,255,0.14)] transition-[background-color,scale] hover:bg-white/15 active:scale-[0.96] lg:inline-flex"
                >
                  Call {contactPhone}
                </a>
              )
            }
            <a
              href="#quote"
              class="inline-flex min-h-10 items-center rounded-lg bg-white px-4 py-2 text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.1)] transition-[background-color,scale] hover:bg-amber-100 active:scale-[0.96]"
            >
              Request quote
            </a>
          </div>
        </nav>
      </header>

      <div class="relative z-10 mx-auto w-full max-w-6xl pt-12">
        <div class="max-w-3xl" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-200">
            Custom illuminated signage in WA
          </p>
          <h1
            class="mt-5 text-balance text-5xl font-semibold leading-[1.02] tracking-normal text-white sm:text-6xl lg:text-7xl"
          >
            Custom commercial lightbox signs for WA businesses
          </h1>
          <p class="mt-6 max-w-2xl text-pretty text-lg leading-8 text-white/82">
            Get indoor and outdoor lightbox signs scoped around site, artwork,
            mounting, visibility, and budget, with survey, design, fabrication,
            installation, and aftercare.
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a
              href="#quote"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-amber-500 px-6 py-3 text-sm font-bold text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.12),0_16px_36px_rgba(242,163,58,0.28)] transition-[background-color,scale,box-shadow] hover:bg-amber-400 active:scale-[0.96]"
            >
              Request a lightbox quote
            </a>
            <a
              href="/preview"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-white/10 px-6 py-3 text-sm font-bold text-white shadow-[0_0_0_1px_rgba(255,255,255,0.18)] transition-[background-color,scale,box-shadow] hover:bg-white/15 active:scale-[0.96]"
            >
              Preview your sign
            </a>
          </div>
          {
            contactLinks.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-3 text-sm font-semibold text-white/82">
                {contactLinks.map((link) => (
                  <a
                    href={link.href}
                    class="inline-flex min-h-10 items-center rounded-lg bg-white/[0.08] px-3 py-2 shadow-[0_0_0_1px_rgba(255,255,255,0.14)] transition-[background-color,scale] hover:bg-white/[0.13] hover:text-white active:scale-[0.96]"
                  >
                    {link.label}: {link.value}
                  </a>
                ))}
              </div>
            )
          }
        </div>
        <dl
          class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-4"
          data-reveal
          data-reveal-delay="1"
        >
          {
            heroHighlights.map(([label, value]) => (
              <div class="rounded-lg bg-white/[0.08] p-4 shadow-[0_0_0_1px_rgba(255,255,255,0.14)]">
                <dt class="text-xs font-bold uppercase tracking-[0.16em] text-amber-200">
                  {label}
                </dt>
                <dd class="mt-2 text-sm leading-6 text-white/82">{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section
      id="applications"
      class="bg-stone-50 px-4 py-20 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
          <div data-reveal>
            <SectionHeader
              kicker="Applications"
              title="Commercial lightbox signs for the places customers actually see."
              copy="The sign type follows the environment: viewing distance, brightness, structure, power, weather, access, and how people approach the business."
            />
          </div>
          <picture
            class="block overflow-hidden rounded-lg bg-stone-200 shadow-[0_0_0_1px_rgba(0,0,0,0.08),0_18px_48px_rgba(0,0,0,0.12)]"
            data-reveal
            data-reveal-delay="1"
          >
            <img
              src={placeholderImages.shopfront.src}
              alt={placeholderImages.shopfront.alt}
              loading="lazy"
              decoding="async"
              width="1536"
              height="1024"
              class="aspect-[16/9] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
            />
          </picture>
        </div>
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            applications.map((item, index) => (
              <article
                class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_42px_rgba(0,0,0,0.07)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <h3 class="text-lg font-semibold text-stone-950">
                  {item.title}
                </h3>
                <p class="mt-4 text-pretty text-sm leading-7 text-stone-600">
                  {item.copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white px-4 py-20">
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="Indoor + outdoor"
            title="One service path, different site details."
            copy="Indoor projects need clean finishes and comfortable illumination. Outdoor projects need structure, weather detail, distance visibility, and service access."
          />
        </div>
        <div class="mt-12 grid gap-5 lg:grid-cols-2">
          {
            capabilityGroups.map((group, index) => (
              <article
                class="rounded-lg bg-stone-50 p-4 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_38px_rgba(0,0,0,0.06)] sm:p-5"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <img
                  src={group.image.src}
                  alt={group.image.alt}
                  loading="lazy"
                  decoding="async"
                  width="1536"
                  height="1024"
                  class="aspect-[16/10] w-full rounded-md object-cover outline outline-1 -outline-offset-1 outline-black/10"
                />
                <div class="p-2 pt-6 sm:p-3 sm:pt-6">
                  <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-800">
                    {group.label}
                  </p>
                  <h3 class="mt-3 text-balance text-2xl font-semibold text-stone-950">
                    {group.title}
                  </h3>
                  <p class="mt-4 text-pretty leading-7 text-stone-600">
                    {group.copy}
                  </p>
                  <ul class="mt-6 grid gap-3">
                  {group.points.map((point) => (
                    <li class="border-l-2 border-amber-400 pl-4 text-sm font-semibold leading-6 text-stone-700">
                      {point}
                    </li>
                  ))}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-[#f3efe7] px-4 py-20">
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="Trust anchors"
            title="Credibility starts with a quote you can check."
            copy="Useful signals are practical: business identity, contact paths, written assumptions, material choices, install notes, and handover checks."
          />
        </div>
        <dl class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {
            identityRows.map(([label, value], index) => (
              <div
                class="rounded-lg bg-white p-4 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_10px_28px_rgba(0,0,0,0.05)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <dt class="text-xs font-bold uppercase tracking-[0.16em] text-teal-800">
                  {label}
                </dt>
                <dd class="mt-2 text-sm font-semibold text-stone-950">
                  {value}
                </dd>
              </div>
            ))
          }
        </dl>
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            trustAnchors.map((anchor, index) => (
              <article
                class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_16px_42px_rgba(0,0,0,0.08)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <p class="text-xs font-bold uppercase tracking-[0.16em] text-teal-800">
                  {anchor.label}
                </p>
                <h3 class="mt-3 text-lg font-semibold text-stone-950">
                  {anchor.title}
                </h3>
                <p class="mt-4 text-pretty text-sm leading-7 text-stone-600">
                  {anchor.copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="specs" class="bg-white px-4 py-20">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div class="grid gap-8" data-reveal>
          <SectionHeader
            kicker="Specification"
            title="The quote should make the build understandable."
            copy="A useful spec names the format, face material, cabinet, LED layout, artwork state, install assumptions, and handover checks."
          />
          <picture class="block overflow-hidden rounded-lg bg-stone-100 shadow-[0_0_0_1px_rgba(0,0,0,0.08),0_14px_38px_rgba(0,0,0,0.09)]">
            <img
              src={placeholderImages.detail.src}
              alt={placeholderImages.detail.alt}
              loading="lazy"
              decoding="async"
              width="1536"
              height="1024"
              class="aspect-[16/10] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
            />
          </picture>
        </div>
        <div class="grid gap-3 md:hidden">
          {
