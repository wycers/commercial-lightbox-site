---
import SectionHeader from "../components/SectionHeader.astro";
import QuoteForm from "../components/QuoteForm";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Send } from "lucide-react";
import {
  absoluteUrl,
  businessAbn,
  businessName,
  businessProfile,
  contactEmail,
  contactPhone,
  emailHref,
  fuelPriceBoardUrl,
  phoneHref,
  serviceArea,
  siteName,
  siteUrl,
} from "../lib/site";

const title = "Commercial Lightbox Signs WA | Perth Lightbox Signage";
const description =
  "Custom commercial lightbox signs for Perth and regional WA businesses, including indoor, shopfront, menu, fascia, and outdoor lightboxes.";

const heroHighlights = [
  ["WA service", `${serviceArea} scoping`],
  ["Path", "Design to install"],
  ["Reply", "Within 1 business day"],
];

const contactLinks = [
  contactPhone
    ? {
        label: "Call",
        value: contactPhone,
        href: phoneHref(contactPhone),
      }
    : null,
  contactEmail
    ? {
        label: "Email",
        value: contactEmail,
        href: emailHref(contactEmail),
      }
    : null,
].filter(Boolean) as Array<{ label: string; value: string; href: string }>;

const conceptImages = {
  shopfront: {
    src: "/images/commercial-lightbox-scope-shopfront-cafe.png",
    alt: "AI-generated concept image of an illuminated shopfront lightbox sign on a modern cafe frontage",
  },
  indoor: {
    src: "/images/commercial-lightbox-scope-indoor-reception.png",
    alt: "AI-generated concept image of an indoor reception lightbox sign in a commercial reception fit-out",
  },
  outdoor: {
    src: "/images/commercial-lightbox-scope-outdoor-fascia.png",
    alt: "AI-generated concept image of an outdoor fascia lightbox sign on a commercial frontage",
  },
  menu: {
    src: "/images/commercial-lightbox-scope-menu-board.png",
    alt: "AI-generated concept image of illuminated menu lightbox panels above a takeaway counter",
  },
  detail: {
    src: "/images/commercial-lightbox-cabinet-detail.png",
    alt: "AI-generated concept detail image of a lightbox cabinet with diffuser face, LEDs, and aluminium housing",
  },
};

const serviceCards = [
  {
    title: "Shopfront lightbox signs",
    href: "/shopfront-lightbox-signs-perth",
    image: conceptImages.shopfront,
    copy: "Fascia, wall-mounted, and window-facing signs built for street presence.",
  },
  {
    title: "Indoor lightbox signs",
    href: "/indoor-lightbox-signs",
    image: conceptImages.indoor,
    copy: "Reception, showroom, and retail lightboxes with clean, comfortable illumination.",
  },
  {
    title: "Outdoor lightbox signs",
    href: "/outdoor-lightbox-signs",
    image: conceptImages.outdoor,
    copy: "Weather-aware cabinets for exposed shopfronts and commercial walls.",
  },
  {
    title: "Menu lightbox signs",
    href: "/menu-lightbox-signs",
    image: conceptImages.menu,
    copy: "Readable illuminated menu panels for counters and food-court queues.",
  },
];

const projectScopes = [
  {
    title: "Shopfront fascia scope",
    image: conceptImages.shopfront,
    scope: "For cafes, clinics, retail tenancies, and street-facing services.",
  },
  {
    title: "Indoor reception scope",
    image: conceptImages.indoor,
    scope: "For lobbies, clinics, showrooms, offices, and front-of-house fit-outs.",
  },
  {
    title: "Cabinet and service scope",
    image: conceptImages.detail,
    scope: "For material choice, lighting layout, and future service access.",
  },
];

const priceGuidance = [
  {
    title: "Scope and inclusions",
    copy: "Type, size, cabinet, face, fabrication, and install.",
  },
  {
    title: "Variables and exclusions",
    copy: "Access, electrical work, artwork redraw, approvals, travel, and wall conditions.",
  },
  {
    title: "Follow-up path",
    copy: "Photos and files can follow after the first reply.",
  },
];

const quoteFactors = [
  {
    title: "Sign size and face",
    copy: "Dimensions, artwork quality, face material, and service access.",
  },
  {
    title: "Indoor or outdoor use",
    copy: "Brightness, diffusion, UV, weather, drainage, and exposure.",
  },
  {
    title: "Mounting and power",
    copy: "Wall condition, cable path, switching, and access equipment.",
  },
  {
    title: "Timing and approvals",
    copy: "Artwork, tenancy rules, landlord approval, travel, and permits.",
  },
];

const materialCareItems = [
  {
    title: "Cabinet and face",
    copy: "Cabinet build, face material, finish, drainage, and access.",
  },
  {
    title: "LEDs and brightness",
    copy: "LED layout, diffuser, power supply, contrast, and viewing distance.",
  },
  {
    title: "Warranty and support",
    copy: "Terms, exclusions, response path, and handover notes.",
  },
  {
    title: "Maintenance path",
    copy: "Cleaning, face replacement, LED access, and power-supply access.",
  },
];

const processSteps = [
  {
    phase: "Enquiry",
    timing: "1 business day",
    copy: "Send the basics. Photos and artwork can follow.",
  },
  {
    phase: "Scope and quote",
    timing: "After site details",
    copy: "Confirm material, access, power, approvals, and timing.",
  },
  {
    phase: "Build and install",
    timing: "Typically a few weeks",
    copy: "Fabricate, install, test illumination, and hand over.",
  },
];

const identityRows = [
  ["Business", businessName],
  ["Coverage", serviceArea],
  ["Response", "Quote response within 1 business day"],
  ["Quote path", "Design, fabricate, install"],
  ...(contactPhone ? [["Phone", contactPhone]] : []),
  ...(contactEmail ? [["Email", contactEmail]] : []),
  ...(businessAbn ? [["ABN", businessAbn]] : []),
];

const quotePrepItems = [
  "Site or shopfront photos",
  "Rough width and height",
  "Logo, artwork, or brand files",
  "Suburb, site type, and sign position",
  "Power, access, timing, and approval notes",
];

const faqs = [
  {
    question: "What lightbox sign types do you make?",
    answer:
      "Shopfront fascia, wall-mounted cabinets, indoor reception signs, retail lightboxes, menu panels, and tenancy signage.",
  },
  {
    question: "Can I ask for a quote before the dimensions are final?",
    answer:
      "Yes. A rough size, site photo, location, sign type, and logo file are enough to start.",
  },
  {
    question: "Do you handle installation?",
    answer:
      "Yes. The path can include survey, design coordination, fabrication, install, testing, and handover.",
  },
  {
    question: "How long does a custom lightbox usually take?",
    answer:
      "Straightforward jobs usually move from scope to install over a few weeks once details are confirmed.",
  },
  {
    question: "What if I also need a fuel price board?",
    answer:
      "Fuel price boards are handled as a specialist range with LED digits, controls, and FuelWatch-ready requirements.",
  },
];

const localBusinessId = `${siteUrl}/#business`;

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": localBusinessId,
      name: businessProfile.tradingName,
      legalName: businessProfile.legalName,
      url: siteUrl,
      areaServed: serviceArea,
      image: absoluteUrl("/images/commercial-lightbox-hero.png"),
      ...(contactPhone ? { telephone: contactPhone } : {}),
      ...(contactEmail ? { email: contactEmail } : {}),
      ...(businessAbn ? { identifier: businessAbn } : {}),
      ...(businessProfile.sameAs?.length
        ? { sameAs: businessProfile.sameAs }
        : {}),
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: siteName,
      url: siteUrl,
      publisher: {
        "@id": localBusinessId,
      },
    },
    {
      "@type": "Service",
      "@id": `${siteUrl}/#commercial-lightbox-service`,
      name: "Custom commercial lightbox signs for WA businesses",
      description,
      serviceType:
        "Commercial lightbox sign design, fabrication, installation, testing, and aftercare",
      areaServed: {
        "@type": "AdministrativeArea",
        name: "Western Australia",
      },
      provider: {
        "@id": localBusinessId,
      },
      url: siteUrl,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  openGraphTitle={title}
  openGraphDescription={description}
  openGraphUrl="/"
>
  <main>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(serviceJsonLd)}
    />
    <a
      id="quote-fab"
      data-quote-fab
      href="#quote"
      aria-label="Jump to quote form"
      class="quote-fab fixed z-40 inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-amber-500 px-4 py-3 text-sm font-bold text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.16),0_18px_42px_rgba(242,163,58,0.34)] transition-[background-color,box-shadow,opacity,scale,transform] hover:bg-amber-400 active:scale-[0.96] focus:outline-none focus:ring-4 focus:ring-amber-300/45"
    >
      <span>Get quote</span>
      <Send className="h-4 w-4" aria-hidden="true" />
    </a>

    <section
      class="relative isolate flex min-h-[86svh] items-center overflow-hidden bg-stone-950 px-4 py-24 text-white"
    >
      <picture class="absolute inset-0 block h-full w-full">
        <source
          media="(max-width: 767px)"
          srcset="/images/commercial-lightbox-hero-mobile.avif"
          type="image/avif"
        />
        <source
          media="(max-width: 767px)"
          srcset="/images/commercial-lightbox-hero-mobile.webp"
          type="image/webp"
        />
        <source
          srcset="/images/commercial-lightbox-hero-desktop.avif"
          type="image/avif"
        />
        <source
          srcset="/images/commercial-lightbox-hero-desktop.webp"
          type="image/webp"
        />
        <img
          src="/images/commercial-lightbox-hero.png"
          alt="Rendered illuminated commercial lightbox sign concept for a modern shopfront"
          width="1672"
          height="941"
          fetchpriority="high"
          decoding="async"
          class="h-full w-full object-cover object-[58%_center] outline outline-1 -outline-offset-1 outline-white/10"
        />
      </picture>
      <div
        class="absolute inset-0 bg-[linear-gradient(90deg,rgba(12,10,9,0.96)_0%,rgba(12,10,9,0.82)_36%,rgba(12,10,9,0.35)_68%,rgba(12,10,9,0.08)_100%)]"
      >
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,10,9,0.14)_0%,rgba(12,10,9,0.03)_48%,rgba(12,10,9,0.74)_100%)]"
      >
      </div>

      <header class="absolute top-0 right-0 left-0 z-20 px-4 py-5">
        <nav
          class="mx-auto flex max-w-6xl items-center justify-between"
          aria-label="Primary"
        >
          <a href="/" class="text-sm font-bold tracking-wide text-white">
            {siteName}
          </a>
          <div class="flex items-center gap-4 text-sm font-semibold text-white/78">
            <a
              href="#services"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Services
            </a>
            <a
              href="#price-guidance"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Quote
            </a>
            <a
              href="#process"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Process
            </a>
            <a
              href="/preview"
              class="hidden transition-[color] hover:text-white sm:inline"
            >
              Preview
            </a>
            {
              contactPhone && (
                <a
                  href={phoneHref(contactPhone)}
                  class="hidden min-h-10 items-center rounded-lg bg-white/10 px-3 py-2 text-white shadow-[0_0_0_1px_rgba(255,255,255,0.14)] transition-[background-color,scale] hover:bg-white/15 active:scale-[0.96] lg:inline-flex"
                >
                  Call {contactPhone}
                </a>
              )
            }
            <a
              href="#quote"
              class="inline-flex min-h-10 items-center rounded-lg bg-white px-4 py-2 text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.1)] transition-[background-color,scale] hover:bg-amber-100 active:scale-[0.96]"
            >
              Request quote
            </a>
          </div>
        </nav>
      </header>

      <div class="relative z-10 mx-auto w-full max-w-6xl pt-12">
        <div class="max-w-3xl" data-reveal>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-200">
            Custom illuminated signage in WA
          </p>
          <h1
            class="mt-5 text-balance text-5xl font-semibold leading-[1.02] tracking-normal text-white sm:text-6xl lg:text-7xl"
          >
            Custom lightbox signs for WA businesses
          </h1>
          <p class="mt-6 max-w-2xl text-pretty text-lg leading-8 text-white/82">
            Indoor, shopfront, menu, fascia, and outdoor lightboxes scoped,
            fabricated, and installed across WA.
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a
              href="#quote"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-amber-500 px-6 py-3 text-sm font-bold text-stone-950 shadow-[0_1px_2px_rgba(0,0,0,0.12),0_16px_36px_rgba(242,163,58,0.28)] transition-[background-color,scale,box-shadow] hover:bg-amber-400 active:scale-[0.96]"
            >
              Request a quote
            </a>
            <a
              href="/preview"
              class="inline-flex min-h-11 items-center justify-center rounded-lg bg-white/10 px-6 py-3 text-sm font-bold text-white shadow-[0_0_0_1px_rgba(255,255,255,0.18)] transition-[background-color,scale,box-shadow] hover:bg-white/15 active:scale-[0.96]"
            >
              Preview your sign
            </a>
          </div>
          {
            contactLinks.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-3 text-sm font-semibold text-white/82">
                {contactLinks.map((link) => (
                  <a
                    href={link.href}
                    class="inline-flex min-h-10 items-center rounded-lg bg-white/[0.08] px-3 py-2 shadow-[0_0_0_1px_rgba(255,255,255,0.14)] transition-[background-color,scale] hover:bg-white/[0.13] hover:text-white active:scale-[0.96]"
                  >
                    {link.label}: {link.value}
                  </a>
                ))}
              </div>
            )
          }
        </div>
        <dl
          class="mt-12 grid gap-3 sm:grid-cols-3"
          data-reveal
          data-reveal-delay="1"
        >
          {
            heroHighlights.map(([label, value]) => (
              <div class="rounded-lg bg-white/[0.08] p-4 shadow-[0_0_0_1px_rgba(255,255,255,0.14)]">
                <dt class="text-xs font-bold uppercase tracking-[0.16em] text-amber-200">
                  {label}
                </dt>
                <dd class="mt-2 text-sm leading-6 text-white/82">{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section
      id="local-trust"
      class="bg-white px-4 py-10 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset,0_1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <dl class="mx-auto grid max-w-6xl gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          identityRows.map(([label, value], index) => (
            <div
              class="rounded-lg bg-stone-50 p-4 shadow-[0_0_0_1px_rgba(0,0,0,0.06)]"
              data-reveal
              data-reveal-delay={String(Math.min(index + 1, 4))}
            >
              <dt class="text-xs font-bold uppercase tracking-[0.16em] text-teal-800">
                {label}
              </dt>
              <dd class="mt-2 text-sm font-semibold text-stone-950">
                {value}
              </dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section
      id="services"
      class="bg-stone-50 px-4 py-20 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="What we make"
            title="Lightbox formats for commercial sites."
            copy="Choose the closest fit. We can combine shopfront, indoor, menu, and outdoor requirements in one quote."
          />
        </div>
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            serviceCards.map((item, index) => (
              <a
                href={item.href}
                class="group block overflow-hidden rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_42px_rgba(0,0,0,0.07)] transition-[box-shadow,scale] hover:scale-[1.01] hover:shadow-[0_0_0_1px_rgba(15,118,110,0.18),0_18px_48px_rgba(0,0,0,0.1)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  loading="lazy"
                  decoding="async"
                  width="1536"
                  height="1024"
                  class="aspect-[16/10] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
                />
                <div class="p-6">
                  <h3 class="text-lg font-semibold text-stone-950">
                    {item.title}
                  </h3>
                  <p class="mt-4 text-pretty text-sm leading-7 text-stone-600">
                    {item.copy}
                  </p>
                  <p class="mt-5 text-sm font-bold text-teal-800 underline decoration-teal-700/35 underline-offset-4 group-hover:text-stone-950 group-hover:decoration-stone-950">
                    Learn more
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="examples"
      class="bg-white px-4 py-20 shadow-[0_-1px_0_rgba(0,0,0,0.06)_inset]"
    >
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="Common project scopes"
            title="Typical starting points."
            copy="Concept images only. Approved project photography can replace them later."
          />
        </div>
        <div class="mt-12 grid gap-5 lg:grid-cols-3">
          {
            projectScopes.map((item, index) => (
              <article
                class="overflow-hidden rounded-lg bg-stone-50 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_16px_42px_rgba(0,0,0,0.07)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  loading="lazy"
                  decoding="async"
                  width="1536"
                  height="1024"
                  class="aspect-[16/10] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
                />
                <div class="p-6">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-amber-700">
                    Concept scope
                  </p>
                  <h3 class="mt-3 text-xl font-semibold text-stone-950">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                    {item.scope}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="price-guidance" class="bg-[#f3efe7] px-4 py-20">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div data-reveal>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-teal-800">
            Quote inclusions
          </p>
          <h2 class="mt-3 text-balance text-3xl font-semibold md:text-4xl">
            Clear inclusions, no hidden assumptions.
          </h2>
          <p class="mt-5 text-pretty text-lg leading-8 text-stone-600">
            The quote should separate confirmed scope from site-dependent items.
          </p>
        </div>
        <div class="grid gap-4">
          {
            priceGuidance.map((item, index) => (
              <article
                class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_36px_rgba(0,0,0,0.06)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <h3 class="text-xl font-semibold text-stone-950">
                  {item.title}
                </h3>
                <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                  {item.copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="quote-factors" class="bg-white px-4 py-20">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
        <div class="grid gap-8" data-reveal>
          <SectionHeader
            kicker="What affects the quote"
            title="Price follows the site."
            copy="Visibility, mounting, exposure, access, artwork, and power all shape the final scope."
          />
          <picture class="block overflow-hidden rounded-lg bg-stone-100 shadow-[0_0_0_1px_rgba(0,0,0,0.08),0_14px_38px_rgba(0,0,0,0.09)]">
            <img
              src={conceptImages.detail.src}
              alt={conceptImages.detail.alt}
              loading="lazy"
              decoding="async"
              width="1536"
              height="1024"
              class="aspect-[16/10] w-full object-cover outline outline-1 -outline-offset-1 outline-black/10"
            />
          </picture>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            quoteFactors.map((factor, index) => (
              <article
                class="rounded-lg bg-stone-50 p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_12px_32px_rgba(0,0,0,0.05)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <h3 class="text-xl font-semibold text-stone-950">
                  {factor.title}
                </h3>
                <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                  {factor.copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="materials" class="bg-stone-50 px-4 py-20">
      <div class="mx-auto max-w-6xl">
        <div data-reveal>
          <SectionHeader
            kicker="Materials and support"
            title="Built details worth specifying."
            copy="Cabinet, face, lighting, warranty, and maintenance access belong in the quote."
          />
        </div>
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            materialCareItems.map((item, index) => (
              <article
                class="rounded-lg bg-white p-6 shadow-[0_0_0_1px_rgba(0,0,0,0.06),0_14px_36px_rgba(0,0,0,0.06)]"
                data-reveal
                data-reveal-delay={String(Math.min(index + 1, 4))}
              >
                <h3 class="text-lg font-semibold text-stone-950">
                  {item.title}
                </h3>
                <p class="mt-3 text-pretty text-sm leading-7 text-stone-600">
                  {item.copy}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="process" class="bg-stone-950 px-4 py-20 text-white">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
          <div data-reveal>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-300">
              How it works
            </p>
            <h2 class="mt-3 text-balance text-3xl font-semibold md:text-4xl">
              A direct path to install.
            </h2>
